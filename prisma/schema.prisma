generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model AgentConfig {
  id              String   @id @default(cuid())
  name            String   @default("Assistente IA")
  systemPrompt    String   @default("Você é um assistente prestativo e amigável.")
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(1024)
  evolutionUrl    String   @default("")
  evolutionApiKey String   @default("")
  instanceId      String   @default("")
  historyLimit    Int      @default(10)
  enabled         Boolean  @default(true)
  allowedPhones   String   @default("")
  aiProvider      String   @default("groq")
  openaiApiKey    String   @default("")
  openaiModel     String   @default("gpt-4.1-mini")
  groqApiKey      String   @default("")
  groqModel       String   @default("llama-3.3-70b-versatile")
  groqTranscriptionModel String @default("whisper-large-v3-turbo")
  groqVisionModel        String @default("llama-3.2-11b-vision-instruct")
  geminiApiKey        String   @default("")
  geminiModel         String   @default("gemini-2.5-flash-lite")
  audioResponseMode   String   @default("on_audio")
  ttsVoice            String   @default("Kore")
  ttsProvider         String   @default("gemini")
  cartesiaApiKey      String   @default("sk_car_3yj7jJ1y5HpBhDNRGfBvHG")
  cartesiaVoiceId     String   @default("c9611be8-aae9-4a93-bb1c-98dd6b7d52a4")
  scheduleEnabled     Boolean  @default(false)
  scheduleTimezone    String   @default("America/Sao_Paulo")
  scheduleDays        String   @default("[1,2,3,4,5]")
  scheduleStartTime   String   @default("08:00")
  scheduleEndTime     String   @default("18:00")
  scheduleOffMessage  String   @default("Olá! No momento estou fora do horário de atendimento. Em breve retornarei! 😊")
  scheduleMode        String   @default("normal")
  schedulePlantaoStart1 String @default("07:30")
  schedulePlantaoEnd1   String @default("12:00")
  schedulePlantaoStart2 String @default("13:00")
  schedulePlantaoEnd2   String @default("17:30")
  textTitleEnabled    Boolean  @default(false)
  textTitle           String   @default("Liz | Assistente Virtual")
  transcriptionProvider String @default("groq")
  visionProvider        String @default("groq")
  observationMode       Boolean  @default(false)
  customPassword        String   @default("")
  securityShieldActive  Boolean  @default(true)
  whatsappProvider      String   @default("evolution")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  source    String    @default("chat")
  phone     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokens         Int?
  mediaType      String?      // "audio" | "image" | "document"
  mediaCaption   String?      // transcrição ou descrição da mídia
  createdAt      DateTime     @default(now())
}
